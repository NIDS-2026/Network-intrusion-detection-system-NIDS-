# ── NIDS API — Environment Variables ──────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# When running with Docker Compose, these are picked up automatically.
#
# For local development (without Docker):
#   Windows PowerShell:  $env:NIDS_API_KEY = "your-key-here"
#   Linux/Mac:           export NIDS_API_KEY="your-key-here"
# ──────────────────────────────────────────────────────────────────────────

# Secret key clients must send in the X-API-Key request header.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
NIDS_API_KEY=change-me-to-a-secure-random-string
